# Copy to .env.local — never commit .env.local

# Supabase (public — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
# Legacy alias still supported by the app:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Receipt uploads (server-only) — create a Blob store under Vercel -> Storage -> Blob
BLOB_READ_WRITE_TOKEN=your-vercel-blob-read-write-token
# Optional tuning (defaults: 1600px max edge, quality 82)
# RECEIPT_MAX_PIXEL_EDGE=1600
# RECEIPT_JPEG_QUALITY=82
